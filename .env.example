# --- Telegram ---
TELEGRAM_BOT_TOKEN=cole_seu_token_aqui

# --- Ollama (local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=gemma:2b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT_S=300

# Fallback chain quando o modelo principal falha (ex.: cloud sem quota).
# CSV em ordem de preferência. Sem tools nesses fallbacks (texto puro).
CHAT_FALLBACK_MODELS=translategemma:4b,gemma:2b

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_API_BASE=https://api.openai.com/v1
# Último recurso de fallback de chat. Vazio = desligado.
OPENAI_CHAT_FALLBACK_MODEL=gpt-4o-mini

# --- Persistência ---
SQLITE_PATH=./data/bot.db
FAISS_INDEX_PATH=./data/faiss.index
FAISS_ID_MAP_PATH=./data/faiss_id_map.json
MEDIA_DIR=./data/media

# Dimensão do modelo de embedding (nomic-embed-text => 768; mxbai-embed-large => 1024).
EMBEDDING_DIM=768

# --- RAG contrastivo ---
RAG_TOP_K=20
RAG_MAX_POSITIVE=3
RAG_MAX_NEGATIVE=2
RAG_POSITIVE_SCORE_THRESHOLD=4
RAG_NEGATIVE_SCORE_THRESHOLD=2
# Quantos exemplos sem score usar quando ainda não há rating (fallback neutro).
RAG_MAX_NEUTRAL=50

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./data/bot.log
# Defina NO_COLOR=1 para desabilitar cores ANSI no console.
