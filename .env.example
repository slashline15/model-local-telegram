# --- Telegram ---
TELEGRAM_BOT_TOKEN=cole_seu_token_aqui

# --- Ollama (local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=gemma:2b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT_S=300

# Fallback chain quando o modelo principal falha (ex.: cloud sem quota).
# CSV em ordem de preferência. Sem tools nesses fallbacks (texto puro).
CHAT_FALLBACK_MODELS=translategemma:4b,gemma:2b

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_WHISPER_TIMEOUT_S=600
# Último recurso de fallback de chat. Vazio = desligado.
OPENAI_CHAT_FALLBACK_MODEL=gpt-4o-mini

# --- Limites de arquivo ---
# Telegram bot API (standard) limita downloads via getFile a 20 MB.
TELEGRAM_DOWNLOAD_MAX_MB=20
# Whisper aceita até 25 MB por requisição.
WHISPER_MAX_MB=25

# --- Timeouts HTTP do Telegram (segundos) ---
# Defaults do PTB são 5s — insuficientes pra arquivos grandes.
TELEGRAM_READ_TIMEOUT_S=60
TELEGRAM_WRITE_TIMEOUT_S=60
TELEGRAM_CONNECT_TIMEOUT_S=30
TELEGRAM_POOL_TIMEOUT_S=30
TELEGRAM_MEDIA_WRITE_TIMEOUT_S=600
TELEGRAM_GET_UPDATES_READ_TIMEOUT_S=30

# --- Persistência ---
SQLITE_PATH=./data/bot.db
SQLITE_BACKUP_DIR=./data/backups
SQLITE_BACKUP_MAX_KEEP=10
SQLITE_BACKUP_ENABLED=true
FAISS_INDEX_PATH=./data/faiss.index
FAISS_ID_MAP_PATH=./data/faiss_id_map.json
MEDIA_DIR=./data/media

# --- Bootstrap ---
# Telegram_id que vira superadmin no primeiro /start. Vazio/0 = sem bootstrap.
# (Para descobrir seu telegram_id, mande qualquer mensagem e olhe os logs ou
#  use @userinfobot.)
BOOTSTRAP_SUPERADMIN_TELEGRAM_ID=0

# Dimensão do modelo de embedding (nomic-embed-text => 768; mxbai-embed-large => 1024).
EMBEDDING_DIM=768

# --- RAG contrastivo ---
RAG_TOP_K=20
RAG_MAX_POSITIVE=3
RAG_MAX_NEGATIVE=2
RAG_POSITIVE_SCORE_THRESHOLD=4
RAG_NEGATIVE_SCORE_THRESHOLD=2
# Quantos exemplos sem score usar quando ainda não há rating (fallback neutro).
RAG_MAX_NEUTRAL=50

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./data/bot.log
# Defina NO_COLOR=1 para desabilitar cores ANSI no console.
